# =============================================================================
# Dineos platform Stripe (SaaS subscriptions)
# Separate from per-restaurant Stripe keys used for guest order checkout.
# =============================================================================

STRIPE_SAAS_SECRET_KEY=sk_test_...
STRIPE_SAAS_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# Recurring prices — monthly / yearly (recommended layout)
#
# In Stripe Dashboard: create two Products (e.g. "Dineos Standard", "Dineos Premium"),
# each with two recurring Prices (monthly + yearly). Paste the six price_… IDs:
# -----------------------------------------------------------------------------

STRIPE_SAAS_PRICE_STANDARD_MONTHLY=price_...
STRIPE_SAAS_PRICE_STANDARD_YEARLY=price_...
STRIPE_SAAS_PRICE_PREMIUM_MONTHLY=price_...
STRIPE_SAAS_PRICE_PREMIUM_YEARLY=price_...

# Optional third tier (only if you sell Advanced in SaaS)
STRIPE_SAAS_PRICE_ADVANCED_MONTHLY=price_...
STRIPE_SAAS_PRICE_ADVANCED_YEARLY=price_...

# -----------------------------------------------------------------------------
# Legacy fallback (one price per tier, no interval split)
# If the _MONTHLY / _YEARLY variables above are unset, the server uses these for
# checkout + webhook tier detection instead.
# -----------------------------------------------------------------------------
# STRIPE_SAAS_PRICE_STANDARD=price_...
# STRIPE_SAAS_PRICE_PREMIUM=price_...
# STRIPE_SAAS_PRICE_ADVANCED=price_...

# Optional: Stripe Customer Portal configuration ID (Dashboard → Billing → Customer portal)
STRIPE_SAAS_PORTAL_CONFIGURATION_ID=

# Webhook endpoint (production): POST https://<your-api-host>/api/v2/webhooks/stripe
# Local: stripe listen --forward-to localhost:5030/api/v2/webhooks/stripe

# Optional: extra browser origins for CORS (comma-separated). Defaults include localhost:* and *.ngrok-free.dev
# CORS_ORIGINS=https://dineos.ae,https://www.dineos.ae

# -----------------------------------------------------------------------------
# Outbound email (Nodemailer / Gmail) — required for guest signup OTP emails
# Use a Gmail App Password, not your normal password:
# https://support.google.com/accounts/answer/185833
# -----------------------------------------------------------------------------
# EMAIL=your.service@gmail.com
# APP_PASSWORD=xxxx xxxx xxxx xxxx
